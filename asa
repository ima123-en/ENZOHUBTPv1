local ObstacleCache = {}
local lastCacheUpdate = 0

local function updateObstacleCache(force)
    local now = tick()
    if not force and (now - lastCacheUpdate < 2) then return end
    lastCacheUpdate = now
    
    table.clear(ObstacleCache)
    
    local descendants = Workspace:GetDescendants()
    for i = 1, #descendants do
        local child = descendants[i]
        local name = child.Name:lower()
        
        local isTarget = false
        for _, targetName in ipairs(TARGET_OBSTACLES) do
            if name:find(targetName, 1, true) then
                isTarget = true
                break
            end
        end
        
        if isTarget then
            if child:IsA("Model") then
                local cf, size = child:GetBoundingBox()
                if size.Magnitude > 2 then
                    table.insert(ObstacleCache, {
                        cf = cf,
                        size = size,
                        name = child.Name
                    })
                end
            elseif child:IsA("BasePart") and child.CanCollide then
                table.insert(ObstacleCache, {
                    cf = child.CFrame,
                    size = child.Size,
                    name = child.Name
                })
            end
        end
    end
end

local function getDynamicMargins(pos, startPos, targetPos)
    local distToStart = (pos - startPos).Magnitude
    local distToTarget = (pos - targetPos).Magnitude
    local minDist = math.min(distToStart, distToTarget)
    
    local baseMarginH = 10 
    local baseMarginV = 3  
    
    if minDist < 15 then
        local factor = minDist / 15
        local marginH = 1.5 + (baseMarginH - 1.5) * factor
        local marginV = 1.0 + (baseMarginV - 1.0) * factor
        return marginH, marginV
    end
    
    return baseMarginH, baseMarginV
end

local function isPointObstructed(pos, startPos, targetPos)
    local marginH, marginV = getDynamicMargins(pos, startPos, targetPos)
    
    for i = 1, #ObstacleCache do
        local obs = ObstacleCache[i]
        local localPos = obs.cf:PointToObjectSpace(pos)
        
        local halfX = (obs.size.X / 2) + marginH
        local halfY = (obs.size.Y / 2) + marginV
        local halfZ = (obs.size.Z / 2) + marginH
        
        if math.abs(localPos.X) <= halfX and 
           math.abs(localPos.Y) <= halfY and 
           math.abs(localPos.Z) <= halfZ then
            return true 
        end
    end
    return false
end

local function checkDirectSight(startPos, endPos, pathStart, pathTarget)
    local distance = (endPos - startPos).Magnitude
    if distance == 0 then return true end
    
    local steps = math.max(6, math.floor(distance / 4))
    for i = 1, steps do
        local checkPos = startPos:Lerp(endPos, i / steps)
        if isPointObstructed(checkPos, pathStart, pathTarget) then
            return false
        end
    end
    return true
end

local function find3DPathAroundWalls(startPos, targetPos)
    updateObstacleCache(true) 
    
    local path = {}
    local maxNodes = 400
    local nodeDistance = 10
    
    local openSet = {}
    local closedSet = {}
    
    table.insert(openSet, {
        pos = startPos,
        parent = nil,
        g = 0,
        f = (startPos - targetPos).Magnitude
    })
    
    local directions = {}
    for x = -1, 1 do
        for y = -1.2, 1.2, 0.6 do 
            for z = -1, 1 do
                if not (x == 0 and y == 0 and z == 0) then
                    table.insert(directions, Vector3.new(x, y, z).Unit)
                end
            end
        end
    end
    
    local foundNode = nil
    
    while #openSet > 0 and maxNodes > 0 do
        maxNodes = maxNodes - 1
        
        local currentIdx = 1
        local current = openSet[1]
        for i, node in ipairs(openSet) do
            if node.f < current.f then
                current = node
                currentIdx = i
            end
        end
        
        if (current.pos - targetPos).Magnitude < nodeDistance or checkDirectSight(current.pos, targetPos, startPos, targetPos) then
            foundNode = current
            break
        end
        
        table.remove(openSet, currentIdx)
        table.insert(closedSet, current.pos)
        
        for i = 1, #directions do
            local dir = directions[i]
            local neighborPos = current.pos + (dir * nodeDistance)
            
            if neighborPos.Y >= startPos.Y - 2 and neighborPos.Y <= startPos.Y + 35 then
                if not isPointObstructed(neighborPos, startPos, targetPos) then
                    local alreadyScanned = false
                    for j = 1, #closedSet do
                        if (closedSet[j] - neighborPos).Magnitude < 3 then
                            alreadyScanned = true
                            break
                        end
                    end
                    
                    if not alreadyScanned then
                        local gScore = current.g + nodeDistance
                        local hScore = (neighborPos - targetPos).Magnitude
                        local fScore = gScore + hScore
                        
                        local inOpen = false
                        for j = 1, #openSet do
                            local openNode = openSet[j]
                            if (openNode.pos - neighborPos).Magnitude < 3 then
                                inOpen = true
                                if gScore < openNode.g then
                                    openNode.g = gScore
                                    openNode.f = fScore
                                    openNode.parent = current
                                end
                                break
                            end
                        end
                        
                        if not inOpen then
                            table.insert(openSet, {
                                pos = neighborPos,
                                parent = current,
                                g = gScore,
                                f = fScore
                            })
                        end
                    end
                end
            end
        end
    end
    
    if foundNode then
        local curr = foundNode
        table.insert(path, 1, targetPos)
        while curr do
            table.insert(path, 1, curr.pos)
            curr = curr.parent
        end
    else
        local midpoint = startPos:Lerp(targetPos, 0.5) + Vector3.new(0, 18, 0)
        table.insert(path, startPos)
        table.insert(path, midpoint)
        table.insert(path, targetPos)
    end
    
    local smoothedPath = { path[1] }
    local i = 1
    while i < #path do
        local nextVisible = i + 1
        for j = #path, i + 2, -1 do
            if checkDirectSight(smoothedPath[#smoothedPath], path[j], startPos, targetPos) then
                nextVisible = j
                break
            end
        end
        table.insert(smoothedPath, path[nextVisible])
        i = nextVisible
    end
    
    return smoothedPath
end

