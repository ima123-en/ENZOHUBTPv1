local function updateFloorPlatforms()
    local sel = getPrioritySelected()
    if not sel then
        ThirdFloorPlatform.CFrame = CFrame.new(0, -1000, 0)
        ThirdFloorPlatform.CanCollide = false
        SecondFloorPlatform.CFrame = CFrame.new(0, -1000, 0)
        SecondFloorPlatform.CanCollide = false
        return
    end
    local brainPos = getBrainrotPosUnified(sel)
    if not brainPos then
        ThirdFloorPlatform.CFrame = CFrame.new(0, -1000, 0)
        ThirdFloorPlatform.CanCollide = false
        SecondFloorPlatform.CFrame = CFrame.new(0, -1000, 0)
        SecondFloorPlatform.CanCollide = false
        return
    end

    if isThirdFloor(brainPos) then
        local airPos = Vector3.new(brainPos.X, brainPos.Y - 7.5, brainPos.Z)
        ThirdFloorPlatform.Position   = airPos - Vector3.new(0, 4.5, 0)
        ThirdFloorPlatform.CanCollide = true
    else
        ThirdFloorPlatform.CFrame = CFrame.new(0, -1000, 0)
        ThirdFloorPlatform.CanCollide = false
    end

    if isSecondFloor(brainPos) and Config.TpSettings.TpFloor1WhenFloor2 then
        local targetY = brainPos.Y - 11
        SecondFloorPlatform.Position = Vector3.new(brainPos.X, targetY, brainPos.Z)
        SecondFloorPlatform.CanCollide = true
    else
        SecondFloorPlatform.CFrame = CFrame.new(0, -1000, 0)
        SecondFloorPlatform.CanCollide = false
    end
end

task.spawn(function()
    while Workspace and Workspace.Parent do
        pcall(updateFloorPlatforms)
        task.wait(0.1)
    end
end)

