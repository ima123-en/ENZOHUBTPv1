local function vZeroLocal(hrp)
    if hrp then
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        hrp.Velocity                = Vector3.zero
        hrp.RotVelocity             = Vector3.zero
    end
end

local function softStabilizeHumanoid(hum)
    if not hum then return end
    if hum.Health <= 0 then return end
    
    hum.PlatformStand = false
    
    hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.PlatformStanding, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
    
    local s = hum:GetState()
    if s == Enum.HumanoidStateType.FallingDown
        or s == Enum.HumanoidStateType.Ragdoll
        or s == Enum.HumanoidStateType.PlatformStanding
        or s == Enum.HumanoidStateType.Freefall then
        
        hum:ChangeState(Enum.HumanoidStateType.Running)
    end
end

local function velMoveThrough(hrp, waypoints, speedOverride)
    if not hrp or not hrp.Parent or #waypoints == 0 then
        return function() end
    end
    local wpIdx = 1
    local done = false
    local conn
    local ARRIVE = 4
    
    equipSelectedTpTool()
    
    local achievedMinDist = math.huge
    local lastWpIdx = 1

    local function hardStop()
        if done then return end
        done = true
        if conn then conn:Disconnect() end
        if hrp and hrp.Parent then
            vZeroLocal(hrp)
        end
    end

    conn = RunService.Heartbeat:Connect(function(dt)
        if not isAlive() then
            _G.TPStatus = "player_died_aborted"
            hardStop()
            return
        end

        if wpIdx ~= lastWpIdx then
            achievedMinDist = math.huge
            lastWpIdx = wpIdx
        end

        local target = waypoints[wpIdx]
        local diff = target - hrp.Position
        local mag = diff.Magnitude

        if mag < achievedMinDist then
            achievedMinDist = mag
        elseif mag > achievedMinDist + 30 then
            _G.TPStatus = "lagback_detected_aborted"
            hardStop()
            return
        end

        if mag < ARRIVE then
            wpIdx = wpIdx + 1
            if wpIdx > #waypoints then
                hardStop()
                return
            end
            target = waypoints[wpIdx]
            diff = target - hrp.Position
            mag = diff.Magnitude
            
            equipSelectedTpTool()
        end
        if mag >= 0.1 then
            local dir = diff.Unit
            local baseSpeed = speedOverride or (_G.VanishCarpetSpeed or Config.TpSettings.TpV2Speed or 160)
            local spd = baseSpeed
            
            if diff.Y > 2 then 
                local slope = diff.Y / mag
                if slope > 0.3 then 
                    spd = baseSpeed / 2 
                end
            end
            
            if wpIdx == #waypoints and mag < 15 then
                spd = spd / 2
            end
            
            hrp.AssemblyLinearVelocity = dir * spd
            softStabilizeHumanoid(hrp.Parent:FindFirstChildOfClass("Humanoid"))
        end
    end)
    return function()
        hardStop()
    end
end

local function executeTravel(targetPos, speed)
    local char = LP.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    vZeroLocal(hrp)
    softStabilizeHumanoid(hum)
    
    local route = find3DPathAroundWalls(hrp.Position, targetPos)
    local stopMove = velMoveThrough(hrp, route, speed)
    
    local t0 = tick()
    local timeout = 8
    local done = false
    
    while tick() - t0 < timeout do
        if not isAlive() or _G.TPStatus == "lagback_detected_aborted" or _G.TPStatus == "player_died_aborted" then 
            break 
        end
        if (hrp.Position - targetPos).Magnitude < 4 then
            done = true
            break
        end
        softStabilizeHumanoid(hum)
        task.wait(0.02)
    end
    stopMove()
    vZeroLocal(hrp)
end

local function sxeFixatePosition(hrp, destPos, facingDir)
    if not hrp or not hrp.Parent then return end
    
    vZeroLocal(hrp)
    hrp.CFrame = CFrame.new(destPos, destPos + facingDir)
    hrp.Anchored = true
    
    local syncFrames = 10
    local syncConn
    syncConn = RunService.Heartbeat:Connect(function()
        if not hrp or not hrp.Parent or syncFrames <= 0 then 
            if syncConn then syncConn:Disconnect() end
            if hrp and hrp.Parent then
                hrp.Anchored = false 
                vZeroLocal(hrp)
            end
            return 
        end
        syncFrames = syncFrames - 1
        hrp.CFrame = CFrame.new(destPos, destPos + facingDir)
        vZeroLocal(hrp)
    end)
    
    local t0 = tick()
    while tick() - t0 < 0.8 do
        local hum = hrp.Parent:FindFirstChildOfClass("Humanoid")
        if hum and hum.FloorMaterial ~= Enum.Material.Air then break end
        task.wait(0.05)
    end
end

local function getBaseIdxByPetPos(pos)
    local closest, dist = 1, math.huge
    for i = 1, 8 do
        local b = BASES_LOW[i]
        local d = (pos.X - b.X)^2 + (pos.Z - b.Z)^2
        if d < dist then dist = d; closest = i end
    end
    return closest
end

local function getBestBasePointInBase(idx, isUpper, playerZ)
    local base = isUpper and BASES_HIGH[idx] or BASES_LOW[idx]
    local frontZ = math.clamp(playerZ - base.Z, -18, 18) + base.Z
    local coord = Vector3.new(base.X, isUpper and 16.85 or -3.04, frontZ)
    local faceDir = (idx <= 4) and Vector3.new(-1, 0, 0) or Vector3.new(1, 0, 0)
    return { pos = coord, look = faceDir }
end

