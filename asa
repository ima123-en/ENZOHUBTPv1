        updateGuiX(i.Position.X)
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        if guiDragging then
            guiDragging = false
            isInteractingWithSlider = false
        end
    end
end)

