local function instantVelocityTpToBrainrot(sel)
    if not sel then return end
    local brainPos = getBrainrotPosUnified(sel)
    if not brainPos then return end

    local targetPos
    if isThirdFloor(brainPos) and ThirdFloorPlatform and ThirdFloorPlatform.Parent then
        local platformTopY = (brainPos.Y - 12) + (ThirdFloorPlatform.Size.Y * 0.5)
        targetPos = Vector3.new(
            ThirdFloorPlatform.Position.X,
            platformTopY + 3,
            ThirdFloorPlatform.Position.Z
        )
    elseif isSecondFloor(brainPos) and Config.TpSettings.TpFloor1WhenFloor2 and SecondFloorPlatform and SecondFloorPlatform.Parent then
        targetPos = Vector3.new(
            SecondFloorPlatform.Position.X,
            (brainPos.Y - 11) + 1.5,
            SecondFloorPlatform.Position.Z
        )
    else
        local char = LP.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        targetPos = getFrontOfBrainrot(hrp, brainPos)
    end

    local freezePosition = targetPos + Vector3.new(0, 1.5, 0)

    for phase = 1, 2 do
        local char = LP.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        
        if not hrp or not hum then break end

        local tpConnections = {}
        local function lockAtTarget()
            if hrp then
                hrp.Anchored = true
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
                hrp.CFrame = CFrame.new(freezePosition)
            end
            equipAnyCarpet()
        end

        table.insert(tpConnections, RunService.RenderStepped:Connect(lockAtTarget))
        table.insert(tpConnections, RunService.Heartbeat:Connect(lockAtTarget))

        task.wait(0.12)

        for _, conn in ipairs(tpConnections) do
            conn:Disconnect()
        end

        if hrp then
            hrp.Anchored = false
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            hrp.CFrame = CFrame.new(freezePosition)
        end

        if hum then
            hum.PlatformStand = false
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            task.wait(0.02)
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end

        if isAlive() then
            local actualDist = (hrp.Position - freezePosition).Magnitude
            if actualDist > 35 then 
                _G.TPStatus = "lagback_detected_aborted"
                return
            end
        else
            _G.TPStatus = "player_died_aborted"
            return
        end

        if phase < 2 then
            task.wait(0.2)
        end
    end

    task.spawn(function()
        task.wait(0.3)
        local char = LP.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.PlatformStanding, true)
        end
    end)
end

local function fireGrappleOnceMouseFree()
