            bypassConnection:Disconnect()
        end
        for _, c in ipairs(hrp:GetChildren()) do
            if c.Name == "FlightPower" or c:IsA("BodyVelocity") then
                c:Destroy()
            end
        end
    end)
    
    return ok
end

local isTeleporting = false
_G.TPStatus = "idle"

local function doVelocityTP()
    if isTeleporting then return end
    isTeleporting = true
    _G.TPStatus = "start"

    local function checkAbort()
        if not isAlive() then
            _G.TPStatus = "player_died_aborted"
            return true
        end
        if _G.TPStatus == "lagback_detected_aborted" then
            return true
        end
        return false
    end

    if checkAbort() then isTeleporting = false; return end

    if not NetModule2 then pcall(loadNet) end
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then
        _G.TPStatus = "no_char"
        isTeleporting = false
        return
    end
    vZeroLocal(hrp)
    softStabilizeHumanoid(hum)
    
    local selData = getPrioritySelected()
    if not selData then
        _G.TPStatus = "no_priority_selection"
        isTeleporting = false
        return
    end
    local savedSel = selData
    local petPos = getBrainrotPosUnified(selData)
    if not petPos then
        _G.TPStatus = "no_pet_position"
        isTeleporting = false
        return
    end

    playPrioritySound()

    local baseIdx   = getBaseIdxByPetPos(petPos)
    local isUpper   = petPos.Y > 7
    if isSecondFloor(petPos) and Config.TpSettings.TpFloor1WhenFloor2 then
        isUpper = false
    end
    
    local bestEntry = getBestBasePointInBase(baseIdx, isUpper, hrp.Position.Z)
    local destPos   = bestEntry.pos
    local facingDir = bestEntry.look

    if checkAbort() then isTeleporting = false; return end

    local travelSpeed = (Config.ToolChoice or "Grapple") == "Grapple" 
        and (Config.TpSettings.TpGrappleSpeed or 260) 
        or (Config.TpSettings.TpV2Speed or 160)

    _G.VanishCarpetSpeed = travelSpeed

    if (Config.ToolChoice or "Grapple") == "Grapple" then
        local origChoice = Config.ToolChoice
        fireGrappleOnceMouseFree()
        task.wait(0.15)
        Config.ToolChoice = "Carpet"
        equipSelectedTpTool()
        
        if isUpper then
            local approachPos = destPos - facingDir * 15
            executeTravel(approachPos, travelSpeed)
            
            if not checkAbort() then
                executeTravel(destPos, travelSpeed)
            end
        else
            executeTravel(destPos, travelSpeed)
        end
        
        Config.ToolChoice = origChoice
        SaveConfig()
    else
        equipSelectedTpTool()
        if isUpper then
            local approachPos = destPos - facingDir * 15
            executeTravel(approachPos, travelSpeed)
            
            if not checkAbort() then
                executeTravel(destPos, travelSpeed)
            end
        else
            executeTravel(destPos, travelSpeed)
        end
    end

    if checkAbort() then isTeleporting = false; return end

    _G.TPStatus = "at_base_before_clone"
    sxeFixatePosition(hrp, destPos, facingDir)

    if checkAbort() then isTeleporting = false; return end

    local currentPos = hrp.Position
    if (currentPos - destPos).Magnitude > 10 then
        _G.TPStatus = "base_not_reached"
        isTeleporting = false
        return
    end
    
    local cd = Config.TpSettings.CloneDelay or 0.03
    cd = math.clamp(cd, 0.01, 1)

    local waitStart = tick()
    while tick() - waitStart < cd do
        if checkAbort() then isTeleporting = false; return end
        task.wait(0.01)
    end
    
    local cloneOk = doCloneUnified()
    if checkAbort() then isTeleporting = false; return end

    if cloneOk then
        task.wait(0.03)
        
        _G.TPStatus = "equip_carpet_wait_0.3s"
        local delayConnections = {}
        local function holdStillAndKeepCarpet()
            if hrp then
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
            end
            if hum then
                hum.PlatformStand = false
                hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
                hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
            equipAnyCarpet()
        end
        table.insert(delayConnections, RunService.Heartbeat:Connect(holdStillAndKeepCarpet))
        
        local waitStart2 = tick()
        while tick() - waitStart2 < 0.3 do
            if checkAbort() then 
                for _, conn in ipairs(delayConnections) do conn:Disconnect() end
                isTeleporting = false; 
                return 
            end
            task.wait(0.01)
        end
        
        for _, conn in ipairs(delayConnections) do
            conn:Disconnect()
        end
        
        if checkAbort() then isTeleporting = false; return end

        local chr  = LP.Character
        local cHrp = chr and chr:FindFirstChild("HumanoidRootPart")
        local cHum = chr and chr:FindFirstChildOfClass("Humanoid")
        if cHrp then 
            vZeroLocal(cHrp) 
            local tag = cHrp:FindFirstChild("_BypassHook")
            if tag then tag:Destroy() end
        end
        softStabilizeHumanoid(cHum)
        equipAnyCarpet()
        
        local mode = Config.TpSettings.TpToBrainrotMode or "Velocity"
        if mode == "Velocity" then
            instantVelocityTpToBrainrot(savedSel)
        elseif mode == "TP" then
            quickDoubleTpToBrainrot(savedSel)
        else
            AfterClone_ThirdFloorAware(savedSel)
        end

        if _G.TPStatus ~= "lagback_detected_aborted" and _G.TPStatus ~= "player_died_aborted" then
            _G.TPStatus = "done"
        end
    else
        _G.TPStatus = "clone_failed"
    end
    isTeleporting = false
end

