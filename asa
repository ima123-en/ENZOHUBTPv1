local function makeSliderSettings(parent, y, labelText, minVal, maxVal, getValue, setValue, formatFn)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.9, 0, 0, 32)
    frame.Position = UDim2.new(0.05, 0, 0, y)
    frame.BackgroundColor3 = Color3.fromRGB(16, 16, 20)
    frame.BorderSizePixel = 0
    frame.Parent = parent
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6, 0, 0, 16)
    label.Position = UDim2.new(0, 8, 0, 4)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.Font = Enum.Font.Gotham
    label.TextSize = 11
    label.TextColor3 = Color3.fromRGB(220, 220, 230)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 70, 0, 16)
    valueLabel.Position = UDim2.new(1, -78, 0, 4)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 11
    valueLabel.TextColor3 = Color3.fromRGB(230, 230, 240)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Parent = frame
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(1, -16, 0, 6)
    bar.Position = UDim2.new(0, 8, 1, -12)
    bar.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    bar.BorderSizePixel = 0
    bar.Parent = frame
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
    fill.BorderSizePixel = 0
    fill.Parent = bar
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 10, 0, 10)
    knob.Position = UDim2.new(0, -5, 0.5, -5)
    knob.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
    knob.BorderSizePixel = 0
    knob.Parent = bar
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local dragging = false
    local function updateVisual(v, instant)
        v = math.clamp(v, minVal, maxVal)
        local alpha = (v - minVal) / (maxVal - minVal)
        local len = bar.AbsoluteSize.X
        local px = alpha * len
        if formatFn then
            valueLabel.Text = formatFn(v)
        else
            valueLabel.Text = string.format("%.2f", v)
        end
        if instant then
            fill.Size = UDim2.new(0, px, 1, 0)
            knob.Position = UDim2.new(0, px - 5, 0.5, -5)
        else
            TweenService:Create(fill, TweenInfo.new(0.1), {Size = UDim2.new(0, px, 1, 0)}):Play()
            TweenService:Create(knob, TweenInfo.new(0.1), {Position = UDim2.new(0, px - 5, 0.5, -5)}):Play()
        end
    end
    local function setFromAlpha(alpha)
        alpha = math.clamp(alpha, 0, 1)
        local v = minVal + (maxVal - minVal) * alpha
        setValue(v)
        updateVisual(v, false)
        SaveConfig()
    end
    bar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            isInteractingWithSlider = true
            local len = bar.AbsoluteSize.X
            local alpha = (i.Position.X - bar.AbsolutePosition.X) / len
            setFromAlpha(alpha)
        end
    end)
    knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            isInteractingWithSlider = true
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local len = bar.AbsoluteSize.X
            local alpha = (i.Position.X - bar.AbsolutePosition.X) / len
            setFromAlpha(alpha)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            isInteractingWithSlider = false
        end
    end)
    task.defer(function()
        updateVisual(getValue(), true)
    end)
end

