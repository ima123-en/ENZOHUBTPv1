local function getBrainrotPosUnified(sel)
    if not sel then return nil end
    if sel.worldPosition then return sel.worldPosition end
    local plots = Workspace:FindFirstChild("Plots")
    if plots and sel.plot and sel.slot then
        local plot    = plots:FindFirstChild(sel.plot)
        local podiums = plot and plot:FindFirstChild("AnimalPodiums")
        local podium  = podiums and podiums:FindFirstChild(tostring(sel.slot))
        if podium then
            local ok, cf = pcall(function() return podium:GetPivot() end)
            if ok then
                local pos = cf.Position
                sel.worldPosition = pos
                return pos
            end
        end
    end
    return nil
end

