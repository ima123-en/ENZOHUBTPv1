local function equipSelectedTpTool()
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    local choice = Config.ToolChoice or "Grapple"
    if choice == "Grapple" then
        local t = findToolLocal("Grapple Hook")
        if t and t:IsA("Tool") then
            if t.Parent ~= char then pcall(function() hum:EquipTool(t) end) end
            return "Grapple Hook"
        end
        return nil
    else
        local wantedName = REAL_TOOL_NAMES[choice] or "Flying Carpet"
        local exact = findToolLocal(wantedName)
        if exact and exact:IsA("Tool") then
            if exact.Parent ~= char then pcall(function() hum:EquipTool(exact) end) end
            return wantedName
        end
        for _, n in ipairs(CARPET_NAMES) do
            local t = findToolLocal(n)
            if t and t:IsA("Tool") then
                if t.Parent ~= char then pcall(function() hum:EquipTool(t) end) end
                return n
            end
        end
    end
    return nil
end

